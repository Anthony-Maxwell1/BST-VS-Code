{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "linux": {
        "command": "bash",
        "args": ["-ic", "source ~/.bashrc && pnpm run watch"]
      },
      "osx": {
        "command": "bash",
        "args": ["-ic", "source ~/.bashrc && pnpm run watch"]
      },
      "windows": {
        "command": "pnpm",
        "args": ["run", "watch"]
      },
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
